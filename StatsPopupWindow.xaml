<Window x:Class="Renamer.StatsPopupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360"
        SizeToContent="Height"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="White" CornerRadius="12"
            BorderBrush="#E5E5EA" BorderThickness="1"
            Padding="16,14" Margin="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.15" Direction="270" />
        </Border.Effect>
        <StackPanel x:Name="StatsPanel" />
    </Border>
</Window>
