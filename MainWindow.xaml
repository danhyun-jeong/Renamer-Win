<Window x:Class="Renamer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Renamer"
        Icon="Renamer_Icon.png"
        Width="360" Height="370"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#FFFFFF">

    <Border BorderBrush="#E5E5EA" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="16,12" Background="White">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="StatusDot" Width="10" Height="10" Margin="0,0,8,0"
                                 Fill="#FF9500" />
                        <TextBlock x:Name="StatusText" Text="동작 중지"
                                   FontFamily="{StaticResource AppFont}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#1C1C1E" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                        <Button x:Name="ToggleBtn" Style="{StaticResource PrimaryButton}"
                                Content="시작" Padding="14,6" FontSize="13"
                                Click="ToggleBtn_Click" />
                        <TextBlock x:Name="NoApiText" Text="API 키 필요"
                                   FontFamily="{StaticResource AppFont}" FontSize="13" Foreground="#FF3B30"
                                   VerticalAlignment="Center" Visibility="Collapsed" />
                    </StackPanel>
                </DockPanel>
            </Border>
            <Rectangle Grid.Row="0" Height="1" Fill="#E5E5EA" VerticalAlignment="Bottom" />

            <!-- Log list — 고정 높이로 남은 공간 전부 사용, 내부 스크롤 -->
            <ScrollViewer Grid.Row="1" x:Name="LogScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="#FAFAFA">
                <Grid>
                    <TextBlock x:Name="EmptyHint"
                               Text="PDF/이미지 파일 감지 시&#x0a;제목 변경 로그가 표시됩니다"
                               FontFamily="{StaticResource AppFont}" FontSize="13" Foreground="#C7C7CC"
                               TextAlignment="Center" HorizontalAlignment="Center"
                               VerticalAlignment="Center" Margin="0,32" LineHeight="22" />
                    <ItemsControl x:Name="LogList" Padding="0,4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="14,5" Background="Transparent">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F2F2F7" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Timestamp, StringFormat={}{0:tt h:mm}, ConverterCulture=ko-KR}"
                                                   FontFamily="{StaticResource AppFont}" FontSize="11"
                                                   Foreground="#8E8E93" VerticalAlignment="Top"
                                                   Margin="0,1,0,0" />
                                        <TextBlock Grid.Column="1" Text="{Binding Message}"
                                                   FontFamily="{StaticResource AppFont}" FontSize="11"
                                                   Foreground="#1C1C1E" TextWrapping="Wrap"
                                                   LineHeight="17" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
            <Rectangle Grid.Row="1" Height="1" Fill="#E5E5EA" VerticalAlignment="Bottom" />

            <!-- Footer -->
            <Border Grid.Row="2" Background="#F2F2F7" Padding="8,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Style="{StaticResource FlatButton}"
                            Content="설정" Click="SettingsBtn_Click" />
                    <Button Grid.Column="1" Style="{StaticResource FlatButton}"
                            Content="통계" Click="StatsBtn_Click" />
                    <Button Grid.Column="2" Style="{StaticResource FlatButton}"
                            Foreground="#FF3B30" Content="종료" Click="QuitBtn_Click" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
