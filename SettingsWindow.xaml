<Window x:Class="Renamer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Renamer 설정"
        Width="440"
        SizeToContent="Height"
        MaxHeight="800"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        Background="#F2F2F7">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Padding="20,20,20,24">
        <StackPanel>

            <!-- API Key Section -->
            <TextBlock Text="Claude API Key 입력하기" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                       Foreground="#8E8E93" Margin="4,0,0,6" />
            <Border Background="White" CornerRadius="10" Padding="14,12" Margin="0,0,0,8">
                <StackPanel>
                    <PasswordBox x:Name="ApiKeyBox" Style="{StaticResource InputPasswordBox}"
                                 FontSize="13" Margin="0,0,0,8" />
                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="#8E8E93"
                               TextWrapping="Wrap" Margin="0,0,0,10"
                               Text="Claude Console(platform.anthropic.com)에서 API Key를 발급할 수 있습니다." />
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="ValidateBtn" Style="{StaticResource PrimaryButton}"
                                Content="검증 및 저장" Padding="14,7"
                                HorizontalAlignment="Left" Click="ValidateBtn_Click" />
                        <TextBlock x:Name="ApiKeyStatus" FontFamily="{StaticResource AppFont}" FontSize="12"
                                   Margin="10,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Model Section -->
            <TextBlock Text="모델" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                       Foreground="#8E8E93" Margin="4,8,0,6" />
            <Border Background="White" CornerRadius="10" Padding="14,12" Margin="0,0,0,8">
                <StackPanel>
                    <!-- Segmented control, centered -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                        <RadioButton x:Name="HaikuRadio" GroupName="Model" Cursor="Hand">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="Bd" CornerRadius="8,0,0,8" Padding="20,7">
                                        <Border.Background>
                                            <SolidColorBrush x:Name="BdBg" Color="#E5E5EA" />
                                        </Border.Background>
                                        <TextBlock x:Name="Lbl" Text="Haiku 4.5"
                                                   FontFamily="{StaticResource AppFont}" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#1C1C1E" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#007AFF" />
                                            <Setter TargetName="Lbl" Property="Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                        <RadioButton x:Name="SonnetRadio" GroupName="Model" Cursor="Hand">
                            <RadioButton.Template>
                                <ControlTemplate TargetType="RadioButton">
                                    <Border x:Name="Bd" CornerRadius="0,8,8,0" Padding="20,7">
                                        <Border.Background>
                                            <SolidColorBrush x:Name="BdBg" Color="#E5E5EA" />
                                        </Border.Background>
                                        <TextBlock x:Name="Lbl" Text="Sonnet 4.6"
                                                   FontFamily="{StaticResource AppFont}" FontSize="13"
                                                   FontWeight="SemiBold" Foreground="#1C1C1E" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#007AFF" />
                                            <Setter TargetName="Lbl" Property="Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </RadioButton.Template>
                        </RadioButton>
                    </StackPanel>
                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="12" Foreground="#8E8E93" TextWrapping="Wrap"
                               Text="Claude에서 어떤 모델을 적용할지 선택할 수 있습니다. Haiku는 가볍고 신속하며 저렴합니다. Sonnet는 좀 더 정확할 수 있지만 토큰 비용이 Haiku에 비해 3배 비쌉니다. 되도록이면 Haiku 사용을 권장합니다." />
                </StackPanel>
            </Border>

            <!-- Processing Targets -->
            <TextBlock Text="적용 대상" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                       Foreground="#8E8E93" Margin="4,8,0,6" />
            <Border Background="White" CornerRadius="10" Padding="14,4" Margin="0,0,0,8">
                <StackPanel>
                    <Grid Margin="0,10,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="PDF" FontFamily="{StaticResource AppFont}" FontSize="13"
                                   Foreground="#1C1C1E" VerticalAlignment="Center" />
                        <ToggleButton x:Name="PdfToggle" Grid.Column="1" Style="{StaticResource ToggleStyle}"
                                      VerticalAlignment="Center" Click="Target_Changed" />
                    </Grid>
                    <Rectangle Height="1" Fill="#E5E5EA" />
                    <Grid Margin="0,10,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="이미지(JPG, PNG 등)" FontFamily="{StaticResource AppFont}" FontSize="13"
                                   Foreground="#1C1C1E" VerticalAlignment="Center" />
                        <ToggleButton x:Name="ImageToggle" Grid.Column="1" Style="{StaticResource ToggleStyle}"
                                      VerticalAlignment="Center" Click="Target_Changed" />
                    </Grid>
                    <TextBlock x:Name="BothOffWarning"
                               Text="⚠️ 모두 비활성화되어 있습니다. '동작 중지' 상태와 사실상 동일합니다."
                               FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="#FF9500"
                               Visibility="Collapsed" Margin="0,0,0,8" />
                </StackPanel>
            </Border>

            <!-- Naming Templates -->
            <TextBlock Text="파일 이름 규칙" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                       Foreground="#8E8E93" Margin="4,8,0,6" />
            <Border Background="White" CornerRadius="10" Padding="14,12" Margin="0,0,0,8">
                <StackPanel>
                    <!-- Article -->
                    <DockPanel Margin="0,0,0,6">
                        <Button DockPanel.Dock="Right" Style="{StaticResource FlatButton}"
                                Content="초기화" FontSize="12" Padding="10,4" Click="ResetArticle_Click" />
                        <TextBlock Text="논문(PDF)" FontFamily="{StaticResource AppFont}" FontSize="13"
                                   Foreground="#1C1C1E" VerticalAlignment="Center" />
                    </DockPanel>
                    <TextBox x:Name="ArticleTemplateBox" Style="{StaticResource InputBox}" FontFamily="Consolas" Margin="0,0,0,6" />
                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="#8E8E93" TextWrapping="Wrap"
                               Margin="0,0,0,14"
                               Text="{}{name}은 저자 이름, {title}은 논문 본제목, {year}은 발행년입니다. 저자가 2명이면 한국어일 경우 가운뎃점(·)으로, 영어일 경우 앤퍼센트(&amp;)로 구분합니다. 저자가 3명 이상이면 대표저자 1인의 이름을 표기한 뒤 한국어일 경우 '외'로, 영어일 경우 'et al.'로 적습니다." />

                    <Rectangle Height="1" Fill="#E5E5EA" Margin="0,0,0,12" />

                    <!-- Poster -->
                    <DockPanel Margin="0,0,0,6">
                        <Button DockPanel.Dock="Right" Style="{StaticResource FlatButton}"
                                Content="초기화" FontSize="12" Padding="10,4" Click="ResetPoster_Click" />
                        <TextBlock Text="포스터 이미지(JPG, PNG 등)" FontFamily="{StaticResource AppFont}" FontSize="13"
                                   Foreground="#1C1C1E" VerticalAlignment="Center" />
                    </DockPanel>
                    <TextBox x:Name="PosterTemplateBox" Style="{StaticResource InputBox}" FontFamily="Consolas" Margin="0,0,0,6" />
                    <TextBlock FontFamily="{StaticResource AppFont}" FontSize="11" Foreground="#8E8E93" TextWrapping="Wrap"
                               Margin="0,0,0,10"
                               Text="{}{title}은 행사 제목, {when}은 날짜(연·월·일)입니다. 콜론(:) 다음의 날짜 포맷을 변경하여 연·월·일 표기 방식을 바꿀 수 있습니다. 예) YY/MM/DD → 26/05/30" />

                    <Button Style="{StaticResource PrimaryButton}" Content="템플릿 저장"
                            Padding="14,7" HorizontalAlignment="Right"
                            Click="SaveTemplates_Click" />
                </StackPanel>
            </Border>

            <!-- Log Settings -->
            <TextBlock Text="로그" FontFamily="{StaticResource AppFont}" FontSize="12" FontWeight="SemiBold"
                       Foreground="#8E8E93" Margin="4,8,0,6" />
            <Border Background="White" CornerRadius="10" Padding="14,12" Margin="0,0,0,8">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="최대 보관 건수" FontFamily="{StaticResource AppFont}" FontSize="13"
                                   Foreground="#1C1C1E" VerticalAlignment="Center" />
                        <ComboBox x:Name="MaxLogCombo" Grid.Column="1" Width="110"
                                  Style="{StaticResource ModernComboBox}"
                                  SelectionChanged="MaxLogCombo_Changed">
                            <ComboBoxItem Content="100건" Tag="100" />
                            <ComboBoxItem Content="250건" Tag="250" />
                            <ComboBoxItem Content="500건" Tag="500" />
                            <ComboBoxItem Content="1000건" Tag="1000" />
                        </ComboBox>
                    </Grid>
                    <Button x:Name="ClearLogBtn" Style="{StaticResource FlatButton}"
                            Content="로그 초기화" Foreground="#FF3B30"
                            HorizontalAlignment="Left" Padding="0,6"
                            Click="ClearLog_Click" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Window>
